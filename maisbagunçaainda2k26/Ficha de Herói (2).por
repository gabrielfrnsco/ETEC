programa {
  funcao inicio() {
    // 1. DECLARAÇÃO: Preparando as caixas
    cadeia nome_heroi
    inteiro nivel, vida_base
    real ouro_inicial
    caracter sigla_classe
    logico missao_ativa

    escreva("--- BEM-VINDO À GUILDA DE AVENTUREIROS ---\n")

    escreva("Digite o nome do seu Herói: ")
    leia(nome_heroi)

    escreva("Qual o nível inicial do herói? ")
    leia(nivel)
  }
}
